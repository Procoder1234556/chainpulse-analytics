# ─── ChainPulse Server Environment ──────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.

# Server
PORT=3001

# Helius RPC (required)
HELIUS_KEY=

# Anthropic / Claude (optional — AI briefs disabled if absent)
ANTHROPIC_KEY=

# Telegram Bot (optional — alerts disabled if absent)
TELEGRAM_BOT_TOKEN=

# Razorpay (optional — payments disabled if absent)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# JWT — must be a long random string in production (required)
JWT_SECRET=