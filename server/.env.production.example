# ─── ChainPulse Production Environment ──────────────────────────────────────
# Fill in real production values.
# NEVER commit the actual .env.production to source control.

PORT=3001
NODE_ENV=production

# The public URL of your deployed frontend (e.g., https://chainpulse.vercel.app)
FRONTEND_URL=

# Helius RPC (required)
HELIUS_KEY=

# Anthropic / Claude (optional)
ANTHROPIC_KEY=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=

# Razorpay (required for payment functionality)
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# JWT — must be a long random string (required)
JWT_SECRET=
